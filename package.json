{
  "name": "project-hub",
  "version": "1.0.0",
  "description": "Centro de control de proyectos",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.projecthub.app",
    "productName": "ProjectHub",
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "files": [
      "main.js",
      "server.js",
      "projects.json",
      "public/**/*",
      "node_modules/**/*"
    ],
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  }
}
